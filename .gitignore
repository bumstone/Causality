__pycache__/
*.py[cod]
.pytest_cache/
.venv/
build/
dist/
*.egg-info/
.causality/
.gstack/
node_modules/

# Runtime / per-run development state — NOT shared (see docs/adr/0008).
# Rule: machine-written runtime artifacts stay local; source, design, and
# curated *.md memory notes stay tracked. The ledger and installed automation
# already live under .causality/ (above).
state.json
*.state.json
# Durable write sidecars for local JSON/JSONL runtime stores.
*.json.lock
*.jsonl.lock
.*.json.*.tmp
.*.jsonl.*.tmp
# Machine-written typed-memory logs (decisions/assumptions/failures/...).
# Note: *.md under memory/ is intentionally NOT ignored, so a curated,
# shareable memory note can be committed without un-ignoring anything.
memory/**/*.jsonl
# Earned-skill store logs (candidates/promoted) — runtime; curated *.md stays tracked.
skills/**/*.jsonl
# Agenda backlog state (runtime / per-project).
agenda.json
*.agenda.json
# Local evaluation/review artifacts (generated HTML reviews) — not shared.
_review/

# OS / editor cruft — machine-local, never shared.
.DS_Store
.idea/
.vscode/
